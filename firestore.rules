rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary testing rules: allow public read, deny writes.
    // DO NOT KEEP THIS IN PRODUCTION.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Example for authenticated access (production):
    // match /{document=**} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
