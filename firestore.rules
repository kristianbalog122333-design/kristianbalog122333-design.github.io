rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read allowed; writes denied by default.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Allow unauthenticated clients to CREATE reservations only in `/rezervace`.
    // Validate required fields to reduce spam and malformed data.
    match /rezervace/{rezId} {
      allow read: if true;
      allow create: if
        // required keys
        request.resource.data.keys().hasAll(['jmeno','telefon','email','datum','od','delka','osoby'])
        // basic types and constraints
        && request.resource.data.jmeno is string
        && request.resource.data.jmeno.size() >= 3
        && request.resource.data.telefon is string
        && request.resource.data.telefon.size() >= 6
        && request.resource.data.email is string
        && request.resource.data.email.matches('^\\S+@\\S+\\.\\S+$')
        && request.resource.data.datum is string
        && request.resource.data.od is string
        && request.resource.data.delka is int
        && request.resource.data.delka == 90
        && request.resource.data.osoby is int
        && request.resource.data.osoby > 0
        && request.resource.data.osoby <= 8;

      // Disallow updates and deletes from client-side.
      allow update, delete: if false;
    }
  }
}
